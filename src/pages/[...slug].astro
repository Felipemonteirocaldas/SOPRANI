---
// Importações de componentes e estilos
import { Head } from "@/components/Head";
import AppRouter from "@/components/Router";
import "@/styles/global.css";

// Definições de SEO para a Soprani
const title = "Soprani Engineering | Industrial Metal Packaging Solutions";
const description = "Global leader in industrial machinery, spare parts, and technical assistance for the metal packaging industry.";
---

<html lang="it" class="w-full h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <Head /> 
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="w-full h-full bg-background text-primary">
    <div id="root" class="w-full h-full">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>